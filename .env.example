# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Calendar (optional — admin shoot sync)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Defaults to {NEXT_PUBLIC_APP_URL}/api/google-calendar/callback if unset
GOOGLE_REDIRECT_URI=

# OneSignal (admin web push) — REST API key is server-only
NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# Email (Resend) — optional; in-app notifications work without this
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_WEBHOOK_SECRET=

# Workflow reminders cron (optional) — GET /api/cron/workflow-reminders with Authorization: Bearer <secret>
CRON_SECRET=
